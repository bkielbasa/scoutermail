{
  "$schema": "https://raw.githubusercontent.com/nicedoc/tauri/refs/heads/main/packages/tauri-cli/config.schema.json",
  "productName": "ScouterMail",
  "version": "0.1.0",
  "identifier": "com.scoutermail.app",
  "build": {
    "frontendDist": "frontend/dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "cd frontend && npm run dev",
    "beforeBuildCommand": "cd frontend && npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "ScouterMail",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 500,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data: blob:; connect-src 'self' ipc: http://ipc.localhost; frame-src 'self' blob: data:"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png"
    ],
    "macOS": {
      "minimumSystemVersion": "10.15",
      "signingIdentity": null
    },
    "category": "Productivity",
    "shortDescription": "A vim-powered desktop email client",
    "longDescription": "ScouterMail is a lightweight, vim-driven desktop email client built for speed with Tauri, Svelte 5, and Rust."
  }
}
